# Copy to .env for local crawls. .env is gitignored — never commit real values.

# User-Agent that UC Merced's WAF allowlists for our crawler. Sent on every
# *.ucmerced.edu request — news feed fetch, robots.txt, and the program
# crawler's Playwright loads (see hostUserAgentOverride in scripts/crawl/user-agent.ts);
# every other host gets the default honest UA. Kept out of the public repo
# because it acts as an allowlist key. In CI it comes from the MERCED_USER_AGENT
# GitHub Actions secret (see .github/workflows/weekly-crawl.yml). Unset → falls
# back to the default UA; Merced 403s and the headed-Chrome fallback below
# takes over (its previous data is preserved if that fails too).
MERCED_USER_AGENT=

# Headed-Chrome bot-block fallback (scripts/crawl/playwright.ts). When a site's
# bot manager denies the headless crawl — every ucmerced.edu host, until their
# UA exception is live — the crawler retries that one fetch on real, headed
# Chrome, whose genuine fingerprint clears the check. Set
# CRAWL_NO_HEADED_FALLBACK=1 to stay strictly headless (e.g. no Chrome
# installed, or you don't want a browser window popping up locally);
# CRAWL_HEADED_CHANNEL picks a different installed channel (default: chrome).
CRAWL_NO_HEADED_FALLBACK=
CRAWL_HEADED_CHANNEL=
