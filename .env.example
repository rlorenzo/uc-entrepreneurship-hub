# Copy to .env for local crawls. .env is gitignored — never commit real values.

# User-Agent that UC Merced's WAF allowlists for our crawler. Sent ONLY for the
# Merced feed fetch (scripts/crawl/news/rss.ts); every other host gets the
# default honest UA. Kept out of the public repo because it acts as an
# allowlist key. In CI it comes from the MERCED_USER_AGENT GitHub Actions
# secret (see .github/workflows/weekly-crawl.yml). Unset → falls back to the
# default UA (Merced will 403 and its previous data is preserved).
MERCED_USER_AGENT=
