#!/bin/sh
#
# Pre-commit hook: run the project check suite before every commit so
# formatting, lint, type, and duplication issues are caught locally
# instead of in CI.
#
# Runs `pnpm run check` = `vp check` (oxfmt format-check + oxlint +
# type-check) then `fallow` (duplication / health scan).
#
# Activated via core.hooksPath=.githooks, set by the package.json
# "prepare" script on `vp install` / `pnpm install`.
#
# Bypass for a single commit with: git commit --no-verify
#
set -e

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pre-commit: pnpm not on PATH, skipping checks (CI will still run them)." >&2
  exit 0
fi

echo "pre-commit: running 'pnpm run check' (format, lint, type-check, fallow)..."
pnpm run check
