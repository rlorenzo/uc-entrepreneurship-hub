{
  "name": "uc-entrepreneurship-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check && fallow",
    "a11y": "node scripts/a11y/run.mjs",
    "a11y:axe": "node scripts/a11y/axe.mjs",
    "a11y:pa11y": "pa11y-ci --config .pa11yci.json",
    "crawl": "node scripts/crawl/run.ts",
    "crawl:news": "node scripts/crawl/news/run.ts",
    "build-data": "node scripts/crawl/build-data.ts",
    "build-news-data": "node scripts/crawl/news/build-data.ts",
    "refresh-data": "vp run crawl && vp run build-data",
    "refresh-news": "vp run crawl:news && vp run build-news-data"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "fallow": "^2.79.0",
    "jsdom": "29.1.1",
    "pa11y-ci": "^4.1.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.22"
  },
  "optionalDependencies": {
    "playwright": "^1.60.0"
  },
  "packageManager": "pnpm@10.33.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "fallow",
      "puppeteer"
    ],
    "overrides": {
      "ws@>=8.0.0 <8.20.1": ">=8.20.1"
    }
  }
}
